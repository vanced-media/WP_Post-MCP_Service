FROM node:22-slim

# Set working directory
WORKDIR /app

# Copy package files
COPY package.json ./

# Enable corepack to use pnpm seamlessly
RUN corepack enable pnpm && pnpm install

# Copy source code
COPY . .

# Expose defined port
ENV PORT=8080
EXPOSE 8080

# Start server safely bypassing shell
CMD ["node", "server.js"]